# AVA GTM — Environment Variables
# Copy to .env and fill in your values

# Apify (Google Maps data source — backup for own scraper)
APIFY_TOKEN=apify_api_your_token_here

# Instantly (email campaign platform)
INSTANTLY_BEARER=your_base64_bearer_token_here
INSTANTLY_CAMPAIGN_ID=your_campaign_uuid_here

# GitHub (auto-deploy — used in run_pipeline.sh)
GITHUB_TOKEN=ghp_your_token_here
